# Server
PORT=5000
CORS_ORIGIN=http://localhost:5173

# MySQL
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=change_me
DB_NAME=mgu_store

# MongoDB CMS
MONGO_URI=mongodb://127.0.0.1:27017
MONGO_DB_NAME=mgu_store_cms
MONGO_APP_NAME=mgu-store-backend
MONGO_MAX_POOL_SIZE=25
MONGO_MIN_POOL_SIZE=2
MONGO_MAX_IDLE_TIME_MS=600000
MONGO_CONNECT_TIMEOUT_MS=10000
MONGO_SOCKET_TIMEOUT_MS=30000
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000

# ImageKit (admin CMS uploads)
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=
IMAGEKIT_UPLOAD_FOLDER=/mgu-store

# Cashfree
CASHFREE_APP_ID=your_app_id
CASHFREE_SECRET_KEY=your_secret
CASHFREE_TEST_MODE=true
CASHFREE_DEFAULT_PHONE=9999999999

# Admin JWT
JWT_SECRET=change_me_long_random

# Proxy plugin (installed on proxy)
PROXY_PLUGIN_HOST=127.0.0.1
PROXY_PLUGIN_PORT=25580
PROXY_PLUGIN_KEY=copy_from_proxy_plugin_key_folder
PROXY_PLUGIN_AUTH_MODE=hmac
PROXY_PLUGIN_TIMEOUT_MS=8000
